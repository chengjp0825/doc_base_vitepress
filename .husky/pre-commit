# Fast pre-commit check: validate local links only in staged docs markdown files.
if git diff --cached --name-only --diff-filter=ACMR -- docs | grep -E '\.(md|mdx)$' >/dev/null 2>&1; then
	echo "[pre-commit] Staged docs markdown detected, running fast link check..."
	npm run check:staged-doc-links
else
	echo "[pre-commit] No staged docs markdown changes, skipping fast link check."
fi
